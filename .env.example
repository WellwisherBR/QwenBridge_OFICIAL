# QwenBridge Configuration
# Only uncomment what you need to change from defaults

# Server
#PORT=3000
#HOST=127.0.0.1
#API_KEY=

# Accounts (required)
QWEN_ACCOUNTS=email1:password1,email2:password2

# Playwright (enabled by default)
#PLAYWRIGHT_ENABLED=true
#PLAYWRIGHT_HEADLESS=true
#PLAYWRIGHT_BROWSER=chromium

# Timeouts (milliseconds) — increase for slow connections
# NAVIGATION_TIMEOUT: page navigation (default: 45000)
# PAGE_TIMEOUT: waitForSelector for UI elements (default: 30000)
# HEADERS_TIMEOUT: header interception during request trigger (default: 60000)
# HTTP_TIMEOUT: API requests (default: 10000)
# CHAT_TIMEOUT: streaming response timeout (default: 120000)
#NAVIGATION_TIMEOUT=45000
#PAGE_TIMEOUT=30000
#HEADERS_TIMEOUT=60000
