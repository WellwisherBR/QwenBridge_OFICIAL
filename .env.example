# QwenBridge Configuration
# Only uncomment what you need to change from defaults

# Server
#PORT=3000
#HOST=0.0.0.0
#INTERNAL_HOST=127.0.0.1
#API_KEY=

# Accounts (required unless you only use guest/public flows)
# Preferred separator: ';' (allows commas inside passwords). ',' is still supported as legacy fallback.
QWEN_ACCOUNTS=email1@example.com:password1;email2@example.com:password2
#DELETE_ALL_CHATS_ON_SHUTDOWN=false

# Password encryption at rest
# If unset, QwenBridge generates and stores a local key at data/db/.encryption_key
#ENCRYPTION_KEY=

# Playwright
#PLAYWRIGHT_HEADLESS=true
#PLAYWRIGHT_BROWSER=chromium
#USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36
#QWEN_BX_V=2.5.36

# Logging / debug
#LOG_LEVEL=info
#CHAT_REQUEST_LOG=false
#REQUEST_DEBUG=false
#TOOLCALL_DEBUG=errors
#UPSTREAM_DEBUG=false

# Timeouts (milliseconds)
#HTTP_TIMEOUT=10000
#CHAT_TIMEOUT=120000
#NAVIGATION_TIMEOUT=45000
#PAGE_TIMEOUT=30000
#HEADERS_TIMEOUT=60000
#TIME_TO_FIRST_BYTE=30000
#IDLE_STREAM_TIMEOUT=60000
#TOTAL_REQUEST_TIMEOUT=300000
#REASONING_MODEL_TIMEOUT=600000

# Cache
#CACHE_TTL=3600
#RESPONSE_TTL=1800
#CACHE_COMPRESSION_ENABLED=true
#CACHE_COMPRESSION_THRESHOLD=1024
#CACHE_COMPRESSION_LEVEL=6

# Context summarization / thread-native session management
#CONTEXT_SUMMARIZATION_ENABLED=true
#CONTEXT_SUMMARIZATION_MODEL=qwen3.5-flash
#CONTEXT_SUMMARIZATION_TIMEOUT=15000
#CONTEXT_PERSISTENCE_ENABLED=true
#CONTEXT_ROLLOVER_ENABLED=true
#CONTEXT_INCREMENTAL_SUMMARY_TOKENS=30000
#CONTEXT_INCREMENTAL_SUMMARY_TURNS=30
#CONTEXT_RECENT_TURNS_TO_KEEP=12
#CONTEXT_SUMMARY_STALE_RATIO=0.70
#CONTEXT_ROLLOVER_READY_RATIO=0.80
#CONTEXT_ROLLOVER_REQUIRED_RATIO=0.90
#CONTEXT_HARD_LIMIT_RATIO=0.95
#CONTEXT_SUMMARY_MAX_TOKENS=4000
#CONTEXT_SUMMARY_TIMEOUT=60000
#CONTEXT_SUMMARY_BACKGROUND_CONCURRENCY=1
#CONTEXT_SUMMARY_MIN_INTERVAL_SECONDS=60
#CONTEXT_SESSION_TTL_HOURS=72
#CONTEXT_MAX_SUMMARIES_PER_SESSION=3
#CONTEXT_MAX_RAW_TURNS_PER_SESSION=100
#CONTEXT_MAX_RAW_TOKENS_PER_SESSION=200000
#CONTEXT_SUMMARY_ALLOW_CROSS_ACCOUNT=true
#CONTEXT_ROLLOVER_ALLOW_CROSS_ACCOUNT=true
#CONTEXT_DELETE_FAILED_NEW_CHATS=true
#CONTEXT_DELETE_OLD_QWEN_CHATS=true
#CONTEXT_OLD_CHAT_RETENTION_HOURS=0

# Retry / anti-bot
#RETRY_BASE_DELAY_MS=1000
#RETRY_MAX_DELAY_MS=10000
#ANTI_BOT_BASE_DELAY_MS=5000
#ANTI_BOT_MAX_DELAY_MS=30000
#ACCOUNT_COOLDOWN_MS=60000

# Qwen upstream behavior
#QWEN_BASE_URL=https://chat.qwen.ai
#QWEN_CHAT_POOL_SIZE=1
#QWEN_CHAT_POOL_MODELS=qwen3.7-plus
#QWEN_PERSONALIZATION_FROM_REQUEST=true
#QWEN_PERSONALIZATION_VERIFY_GET=true

# Metrics / watchdog
#METRICS_INTERVAL=10000
#WATCHDOG_INTERVAL=5000
#WATCHDOG_FAILURES=3
#RAM_WARNING=80
#RAM_CRITICAL=95
#WS_WARNING=50
#WS_CRITICAL=100
